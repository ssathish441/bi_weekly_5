import java.util.*;

class Solution {
    int solve(ArrayList<Integer> nums) {
        int n=nums.size();
        if(n<=2) return n;
        int k=2;
        for(int i=2; i<n; i++){
            if(!nums.get(i).equals(nums.get(k-2))){
                nums.set(k,nums.get(i));
                k++;
            }
        }
        return k;
    }
}
